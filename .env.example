# ════════════════════════════════════════════
# Postgres Railway (ya tienes corriendo)
# ════════════════════════════════════════════
DATABASE_URL=postgresql://user:pass@host:port/db

# ════════════════════════════════════════════
# Telegram bot
# Crea bot en @BotFather → obtén token
# chat_id: manda msg al bot, visita
# https://api.telegram.org/bot<TOKEN>/getUpdates
# ════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ════════════════════════════════════════════
# YouTube — branding de tu canal (ver README para setup del canal/OAuth)
# ════════════════════════════════════════════
YT_CLIENT_SECRET=secrets/client_secret.json
YT_TOKEN=secrets/token.pickle
CHANNEL_HANDLE=@yourchannel
CHANNEL_NAME=My Ambient Channel
CHANNEL_ARTIST=My Ambient Channel
# Tema/nicho del canal, usado en docs y (opcionalmente) en tu propio código.
CHANNEL_DESCRIPTION=ambient / sleep / instrumental mood music

# ════════════════════════════════════════════
# Asset paths
# ════════════════════════════════════════════
RAW_TRACKS_DIR=data/raw_tracks
PROCESSED_DIR=data/processed
VIDEOS_DIR=data/videos
THUMBNAILS_DIR=data/thumbnails
LOOPS_DIR=assets/loops
AVATAR_DIR=assets/avatar
FONTS_DIR=assets/fonts
OVERLAYS_DIR=assets/overlays

# ════════════════════════════════════════════
# Tuning
# ════════════════════════════════════════════
TARGET_LUFS=-14.0
COMPILATION_DURATION_SEC=3600
UPLOAD_HOUR_LOCAL=21
TIMEZONE=America/Santiago

# ════════════════════════════════════════════
# Overlay + fade
# Si OVERLAYS_DIR está vacío → no se aplica overlay (backward compatible)
# Blend modes: screen (default), lighten, add
# ════════════════════════════════════════════
OVERLAY_OPACITY=0.30
OVERLAY_BLEND_MODE=screen
FADE_IN_SEC=2.0
FADE_OUT_SEC=3.0
# Categoría usada cuando ningún keyword matchea el suno_prompt del track.
# Vacío = no fallback (sin overlay si no hay match).
DEFAULT_OVERLAY=rain

# AI disclosure flag para YouTube. Para música ambient/instrumental
# artística NO es mandatorio (YouTube lo exige solo cuando puede engañar
# sobre eventos/personas reales). Setear true solo si haces contenido que
# imite a alguien real o eventos verídicos falsos.
AI_DISCLOSURE=false
